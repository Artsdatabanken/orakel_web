# Copy to .env.local and fill in. Both values are read at build time
# by Vite (envPrefix is set to ORAKEL_ in vite.config.js) and inlined
# into the bundle. In Azure Pipelines these are set as secret pipeline
# variables, distinct per environment (test vs prod).

# Test endpoint by default. Production builds (deployed to
# orakel.artsdatabanken.no) override this to https://ai.artsdatabanken.no/identify
# via pipeline variables. If unset, src/config.js falls back to the test
# endpoint everywhere except orakel.artsdatabanken.no.
ORAKEL_API_URL=https://ai.test.artsdatabanken.no/identify
ORAKEL_API_TOKEN=
